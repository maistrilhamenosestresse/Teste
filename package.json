    "leaflet": "^1.9.4",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.79.0",
    "react-leaflet": "^5.0.0",
    "react-signature-canvas": "^1.1.0-alpha.2",
