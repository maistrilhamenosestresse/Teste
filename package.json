    "db:migrate": "node scripts/apply-supabase-migration.mjs",
    "readiness:check": "node scripts/verify-production-readiness.mjs",
    "readiness:test": "node scripts/verify-production-readiness.mjs --allow-sandbox"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1087.0",
